  "disabled_extensions": [
    "clojure", "coffeescript", "csharp", "dart", "fsharp", "go",
    "groovy", "grunt", "gulp", "handlebars", "hlsl", "jake",
    "java", "julia", "latex", "less", "objective-c",
    "perl", "php", "php-language-features", "pug", "r", "razor",
    "restructuredtext", "ruby", "rust", "scss", "shaderlab",
    "swift", "typescript-basics", "typescript-language-features", "vb"
  ],
  "db_permissions": {
    "agent_prefs_b64": ""
  },
  "db_journal_mode": "wal"
}
